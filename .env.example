# Database
DATABASE_URL="postgresql://user:password@localhost:5432/jefocus?schema=public"

# Clerk
# DEV  -> pk_test_... / sk_test_...  (Clerk shows the "Development mode" badge)
# PROD -> pk_live_... / sk_live_...  (removes "Development mode"; needs a Production
#         instance + custom domain + DNS configured in the Clerk Dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
